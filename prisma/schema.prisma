generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Material {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  currentCost     Float
  marketCost      Float
  supplier        String
  inventoryItems  InventoryItem[]
  marketSignals   MarketSignal[]
  orders          Order[]
  shipments       Shipment[]
  structuralRisks StructuralRisk[]
}

model Order {
  id                     String                  @id
  client                 String
  margin                 String
  materialId             Int
  material               Material                @relation(fields: [materialId], references: [id])
  pricingRecommendations PricingRecommendation[]
}

model Shipment {
  id              Int            @id @default(autoincrement())
  materialId      Int
  qty             String
  supplier        String
  currentNode     String
  eta             String
  status          String
  gemmaAnnotation String
  material        Material       @relation(fields: [materialId], references: [id])
  steps           ShipmentStep[]
}

model ShipmentStep {
  id         Int      @id @default(autoincrement())
  shipmentId Int
  name       String
  status     String
  sequence   Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model MarketSignal {
  id         Int       @id @default(autoincrement())
  title      String
  source     String
  date       String
  relevance  String
  tag        String
  desc       String
  materialId Int?
  material   Material? @relation(fields: [materialId], references: [id])
}

model PricingRecommendation {
  id         String  @id
  trigger    String
  action     String
  confidence String
  reasoning  Json
  accepted   Boolean @default(false)
  rejected   Boolean @default(false)
  expanded   Boolean @default(false)
  orderId    String?
  order      Order?  @relation(fields: [orderId], references: [id])
}

model StructuralRisk {
  id            Int       @id @default(autoincrement())
  trend         String
  status        String
  title         String
  description   String
  gemmaAdvisory String
  materialId    Int?
  material      Material? @relation(fields: [materialId], references: [id])
}

model IndustryNews {
  id       Int    @id @default(autoincrement())
  title    String
  source   String
  date     String
  summary  String
  category String
  image    String
  url      String
}

model InventoryItem {
  id           Int       @id @default(autoincrement())
  name         String
  category     String
  sku          String    @unique
  quantity     Int
  unit         String
  location     String
  minThreshold Int
  status       String
  image        String
  lastUpdated  DateTime  @default(now())
  materialId   Int?
  material     Material? @relation(fields: [materialId], references: [id])
}

model CncMachineTelemetry {
  id              Int      @id @default(autoincrement())
  machineId       String
  airTemp         Float
  processTemp     Float
  rotationalSpeed Float
  torque          Float
  toolWear        Float
  machineFailure  Boolean
  twf             Boolean
  hdf             Boolean
  pwf             Boolean
  osf             Boolean
  rnf             Boolean
  timestamp       DateTime @default(now())
}

model IndianMetalIndex {
  id          Int      @id @default(autoincrement())
  source      String
  material    String
  region      String
  price       Float
  unit        String
  change      Float
  lastUpdated DateTime @default(now())
}
