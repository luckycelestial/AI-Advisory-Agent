// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Material {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  currentCost     Float
  marketCost      Float
  supplier        String
  orders          Order[]
  shipments       Shipment[]
  inventoryItems  InventoryItem[]
  marketSignals   MarketSignal[]
  structuralRisks StructuralRisk[]
}

model Order {
  id                     String                  @id
  client                 String
  margin                 String
  materialId             Int
  material               Material                @relation(fields: [materialId], references: [id])
  pricingRecommendations PricingRecommendation[]
}

model Shipment {
  id              Int            @id @default(autoincrement())
  materialId      Int
  material        Material       @relation(fields: [materialId], references: [id])
  qty             String
  supplier        String
  currentNode     String
  eta             String
  status          String
  gemmaAnnotation String
  steps           ShipmentStep[]
}

model ShipmentStep {
  id         Int      @id @default(autoincrement())
  shipmentId Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  name       String
  status     String
  sequence   Int
}

model MarketSignal {
  id         Int       @id @default(autoincrement())
  title      String
  source     String
  date       String
  relevance  String
  tag        String
  desc       String
  materialId Int?
  material   Material? @relation(fields: [materialId], references: [id])
}

model PricingRecommendation {
  id         String  @id
  trigger    String
  action     String
  confidence String
  reasoning  Json // list of strings representing the reasoning trail
  accepted   Boolean @default(false)
  rejected   Boolean @default(false)
  expanded   Boolean @default(false)
  orderId    String?
  order      Order?  @relation(fields: [orderId], references: [id])
}

model StructuralRisk {
  id            Int       @id @default(autoincrement())
  trend         String
  status        String
  title         String
  description   String
  gemmaAdvisory String
  materialId    Int?
  material      Material? @relation(fields: [materialId], references: [id])
}

model IndustryNews {
  id       Int    @id @default(autoincrement())
  title    String
  source   String
  date     String
  summary  String
  category String
  image    String
  url      String
}

model InventoryItem {
  id           Int       @id @default(autoincrement())
  name         String
  category     String // "Raw Material" | "Tooling" | "WIP" | "Finished"
  sku          String    @unique
  quantity     Int
  unit         String // "pcs" | "kg" | "meters"
  location     String // "Rack A-1", "Bin 3", etc.
  minThreshold Int // for reorder alerts
  status       String // "In Stock" | "Low Stock" | "Out of Stock"
  image        String // public path, e.g. "/inventory/aluminum-blocks.png"
  lastUpdated  DateTime  @default(now())
  materialId   Int?
  material     Material? @relation(fields: [materialId], references: [id])
}

model CncMachineTelemetry {
  id              Int      @id @default(autoincrement())
  machineId       String // e.g. "CNC-Milling-01"
  airTemp         Float
  processTemp     Float
  rotationalSpeed Float
  torque          Float
  toolWear        Float // in minutes
  machineFailure  Boolean
  twf             Boolean // Tool Wear Failure
  hdf             Boolean // Heat Dissipation Failure
  pwf             Boolean // Power Failure
  osf             Boolean // Overstrain Failure
  rnf             Boolean // Random Failure
  timestamp       DateTime @default(now())
}

model IndianMetalIndex {
  id          Int      @id @default(autoincrement())
  source      String // "Tata nexarc" | "SteelonCall" | "BigMint" | "Ministry WPI"
  material    String // "TMT Rebars" | "Mild Steel Billets" | "Sponge Iron" | "Steel Index (WPI)"
  region      String // "Bengaluru (Peenya)" | "Chennai (Jigani)" | "Mumbai" | "National Average"
  price       Float // price in INR (or index base points)
  unit        String // "per Ton" | "index points"
  change      Float // percentage change
  lastUpdated DateTime @default(now())
}
